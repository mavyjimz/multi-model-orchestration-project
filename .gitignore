# Phase 3: Vector Database (large binary files) - COMPREHENSIVE
data/vector_db/
data/**/vector_db/
**/faiss_index_*/
*.faiss
*.faiss.index

# Pickle files (except specific ones)
data/**/*.pkl
!data/final/vectorizer.pkl
!data/final/all_index_maps.pkl

# Large numpy arrays
data/**/*.npy
data/**/*.npz

# JSON metadata (keep small ones, ignore large)
data/vector_db/**/*.json
!data/final/**/*.json

# Temporary and cache files
*.tmp
*.cache
.cache/
tmp/

# ========================================
# Phase 4: Model Development
# ========================================

# Phase 4 trained models (large binaries - keep in models/phase4/ but don't commit)
models/phase*/
models/phase4_baseline/
models/*.pkl
models/**/*.pkl

# MLflow artifacts (auto-generated tracking data)
mlruns/
mlruns/**/*
mlflow.db

# Phase 4 temporary files
phase4_temp/
*.tmp.phase4

# Keep only lightweight model metadata
!models/phase4/MANIFEST.json
!models/phase4/README.md

# Updated Phase 4 exceptions - track manifests and metadata
!models/phase4/*.json
!models/phase4/README.md
!models/phase4/*.txt
models/registry/*/*.pkl
models/registry/**/*.pkl

# ========================================
# Phase 5: Model Validation & Testing
