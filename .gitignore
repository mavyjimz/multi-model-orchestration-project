!results/phase5/*.json
!results/phase5/*.csv
!results/phase5/*.png
!results/phase5/*.txt
!results/phase5/*.xml
!results/phase5/*.yaml

# Phase 5 test artifacts
!tests/*.py
!tests/**/*.py

