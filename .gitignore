# Data files (generated) - EXCLUDE ALL LARGE FILES
data/processed/*.csv
data/embeddings/*.npy
data/embeddings/*.pkl
data/final/
data/final/**/*.npy
data/final/**/*.pkl

# Logs - Keep metrics and visualizations, ignore debug logs
logs/*.log
logs/debug.log
logs/verbose.log
!logs/p3.*_metrics.json
!logs/*.png

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local

# Model checkpoints (if any)
*.h5
*.pth
*.pt
*.onnx

# Input data (raw/intermediate files)
input-data/processed/
input-data/raw/
input-data/router/
input-data/splits/

# Phase 3: Vector Database (large binary files) - COMPREHENSIVE
data/vector_db/
data/**/vector_db/
**/faiss_index_*/
*.faiss
*.faiss.index

# Pickle files (except specific ones)
data/**/*.pkl
!data/final/vectorizer.pkl
!data/final/all_index_maps.pkl

# Large numpy arrays
data/**/*.npy
data/**/*.npz

# JSON metadata (keep small ones, ignore large)
data/vector_db/**/*.json
!data/final/**/*.json

# Temporary and cache files
*.tmp
*.cache
.cache/
tmp/
