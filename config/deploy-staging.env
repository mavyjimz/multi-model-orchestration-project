# Staging Environment Configuration
# Copy to .env and fill in secrets

# Registry API
REGISTRY_HOST=0.0.0.0
REGISTRY_PORT=8000

# MLflow Tracking
MLFLOW_TRACKING_URI=mlflow://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/registry-api.log
AUDIT_LOG=/app/logs/audit/registry-audit.json

# Resource Limits (for docker-compose)
MEMORY_LIMIT=2g
CPU_LIMIT=2

# Deployment
DEPLOY_ENV=staging
AUTO_RESTART=true
HEALTH_CHECK_INTERVAL=30s
