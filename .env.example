# Phase 10: Security & Governance - Environment Template
# Copy to .env and fill values. NEVER commit .env to git.

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Audit Logging
AUDIT_LOG_PATH=logs/audit.log
AUDIT_TAMPER_HASH_SECRET=your-audit-hash-secret

# GDPR Compliance
DATA_RETENTION_DAYS=365
ENABLE_RIGHT_TO_ERASE=true

# HTTPS (Self-Signed for Phase 10)
SSL_CERT_PATH=certs/selfsigned.crt
SSL_KEY_PATH=certs/selfsigned.key

# Secrets (GitHub Actions will inject these in CI/CD)
# Local dev only below:
DATABASE_URL=sqlite:///./data/app.db
MLFLOW_TRACKING_URI=file:./mlruns
